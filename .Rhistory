RQ$HK_geomean <- exp(rowMeans(log(RQ[hk_genes1])))
RQ$RQ_AMP_normalized <- RQ$AMP / RQ$HK_geomean
RQ$condition <- condition
RQ_select <- RQ[,c('condition',"RQ_AMP_normalized")]
View(RQ)
View(RQ_select)
fit <- aov(RQ_AMP_normalized ~ condition, data = RQ_select)
summary(fit)
tukey <- TukeyHSD(fit)
tukey
line_means <- aggregate(RQ_AMP_normalized ~ condition, RQ_select, mean)
line_means_sorted <- line_means %>% arrange(RQ_AMP_normalized)
